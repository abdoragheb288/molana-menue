rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net: Default to deny all read/write
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Path ID Hardening (Injection Protection)
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 3. User & Administrative Identity Helpers
    // The admin of Moulana is abdoragheb288@gmail.com, bootstrapped here.
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email == 'abdoragheb288@gmail.com';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 4. Standalone Validation Blueprint for Menu Items
    function isValidMenuItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 && data.price <= 10000 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 100 &&
             data.description is string && data.description.size() <= 1000 &&
             (!data.keys().hasAll(['imageUrl']) || (data.imageUrl is string && data.imageUrl.size() <= 2000)) &&
             (!data.keys().hasAll(['availability']) || data.availability is bool);
    }

    // 5. Standalone Validation Blueprint for Orders
    function isValidOrder(data) {
      return data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 100 &&
             data.phone is string && data.phone.size() >= 5 && data.phone.size() <= 30 &&
             (!data.keys().hasAll(['address']) || (data.address is string && data.address.size() <= 500)) &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 100 &&
             data.orderType is string && (data.orderType == 'Takeaway' || data.orderType == 'Delivery') &&
             data.status is string && (data.status == 'pending' || data.status == 'processing' || data.status == 'completed' || data.status == 'cancelled') &&
             data.totalAmount is number && data.totalAmount >= 0 && data.totalAmount <= 1000000;
    }

    // 6. Menu Collection Rules (Public Reads, Admin-Only Writes)
    match /menu/{menuItemId} {
      allow read: if true; // Any customer can retrieve menu items

      allow create: if isAdmin() &&
                    isValidId(menuItemId) &&
                    incoming().keys().hasAll(['name', 'price', 'category', 'description', 'createdAt', 'updatedAt']) &&
                    incoming().keys().size() >= 6 && incoming().keys().size() <= 8 &&
                    isValidMenuItem(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;

      allow update: if isAdmin() &&
                    isValidId(menuItemId) &&
                    isValidMenuItem(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;

      allow delete: if isAdmin() && isValidId(menuItemId);
    }

    // 7. Orders Collection Rules
    match /orders/{orderId} {
      // General list is restricted to admin.
      // Individual get is allowed for the placing customer (via orderId) or the admin.
      allow get: if isValidId(orderId);
      allow list: if isAdmin();

      // Anyone can submit a valid order starting as pending
      allow create: if isValidId(orderId) &&
                    incoming().keys().hasAll(['customerName', 'phone', 'items', 'orderType', 'status', 'totalAmount', 'createdAt', 'updatedAt']) &&
                    incoming().keys().size() >= 8 && incoming().keys().size() <= 9 &&
                    isValidOrder(incoming()) &&
                    incoming().status == 'pending' &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;

      // Status tracking and order updates can only be executed by Admin
      allow update: if isAdmin() &&
                    isValidId(orderId) &&
                    isValidOrder(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;

      allow delete: if isAdmin() && isValidId(orderId);
    }
  }
}
